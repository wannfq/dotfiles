{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "skill": {
      "*": "allow"
    },
    "github_*": "ask"
  },
  "server": {
    "port": 4096
  },
  "mcp": {
    "github": {
      "enabled": false,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    }
  },
  "plugin": [
    "oh-my-opencode-slim",
    "@slkiser/opencode-quota"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "build": {
      "color": "#FAB387"
      // "color": "#74C7EC"
    },
    "plan": {
      "color": "#CBA6F7"
    },
    "orchestrator": {
      "color": "#A6E3A1"
    }
  },
  "lsp": true
}
