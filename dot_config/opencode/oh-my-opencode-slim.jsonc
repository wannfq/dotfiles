{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "preset": "hybrid",
  "council": {
    "default_preset": "default",
    "timeout": 120000,
    "councillor_execution_mode": "parallel",
    "councillor_retries": 3,
    "presets": {
      "default": {
        "alpha": { "model": "opencode-go/deepseek-v4-flash" },
        "beta": { "model": "opencode-go/deepseek-v4-flash" },
      },
    },
  },
  "presets": {
    "openai": {
      "orchestrator": {
        "model": "openai/gpt-5.5",
        "skills": ["*"],
        "mcps": ["*", "!context7"],
      },
      "oracle": {
        "model": "openai/gpt-5.5",
        "variant": "high",
        "skills": ["simplify"],
