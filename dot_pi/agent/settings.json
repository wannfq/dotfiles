{
  "lastChangelogVersion": "0.81.1",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.6-terra",
  "subagents": {
    "defaultModel": "opencode-go/deepseek-v4-pro",
    "agentOverrides": {
      "context-builder": {
        "thinking": "high"
      },
      "delegate": {
        "thinking": "medium"
      },
      "oracle": {
        "model": "openai-codex/gpt-5.6-sol",
        "thinking": "medium"
      },
      "planner": {
        "model": "openai-codex/gpt-5.6-terra",
        "thinking": "high"
      },
      "researcher": {
        "thinking": "high"
      },
      "reviewer": {
        "model": "opencode-go/kimi-k2.7-code",
        "thinking": "high"
      },
      "scout": {
        "thinking": "high"
      },
      "worker": {
        "model": "openai-codex/gpt-5.6-terra",
        "thinking": "high"
      }
    },
    "watchdog": {
      "main": {
        "model": "openai-codex/gpt-5.6-terra",
        "thinking": "high"
      }
    }
  },
  "packages": [
    "npm:pi-cozy-ui",
    "npm:pi-lens",
    "npm:@ff-labs/pi-fff",
    "npm:@wierdbytes/pi-peon",
    "npm:pi-subagents",
    "npm:@juicesharp/rpiv-todo",
    "npm:@juicesharp/rpiv-web-tools",
    "npm:@juicesharp/rpiv-ask-user-question",
    "npm:@juicesharp/rpiv-btw",
    "npm:@mnemosyne-oss/pi-mnemosyne"
  ],
  "defaultThinkingLevel": "medium",
  "hideThinkingBlock": true,
  "terminal": {
    "imageWidthCells": 120
  },
  "theme": "cozy-dark",
  "enabledModels": [
    "opencode-go/deepseek-v4-flash",
    "opencode-go/deepseek-v4-pro",
    "opencode-go/minimax-m3",
    "opencode-go/glm-5.2",
    "opencode-go/kimi-k2.7-code",
    "neuralwatt/glm-5.2",
    "neuralwatt/glm-5.2-flex",
    "neuralwatt/glm-5.2-short",
    "neuralwatt/kimi-k2.6",
    "neuralwatt/kimi-k2.6-flex",
    "neuralwatt/kimi-k2.7-code",
    "neuralwatt/kimi-k2.7-code-flex",
    "openai-codex/gpt-5.6-terra",
    "openai-codex/gpt-5.6-luna",
    "openai-codex/gpt-5.6-sol"
  ],
  "quietStartup": true
